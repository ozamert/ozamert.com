---
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
---

<header>
  <nav>
    <a href="/" class="site-name">ozamert</a>

    <div class="spacer"></div>

    <div class="nav-right">
      <!-- Tech monogram badges -->
      <div class="badge-group">
        <a
          href="/data-engineering"
          class:list={['badge', { active: isActive('/data-engineering') }]}
          title="Data Engineering"
        >DE</a>
        <a
          href="/data-science"
          class:list={['badge', { active: isActive('/data-science') }]}
          title="Data Science"
        >DS</a>
        <a
          href="/ml-engineering"
          class:list={['badge', { active: isActive('/ml-engineering') }]}
          title="ML Engineering"
        >MLE</a>
      </div>

      <span class="sep"></span>

      <!-- Projects (text) + Demos (icon) -->
      <div class="work-group">
        <a href="/projects" class:list={['text-link', { active: isActive('/projects') }]}>projects</a>
        <a href="/demos" class:list={['icon-link', { active: isActive('/demos') }]} title="Demos" aria-label="Demos">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/>
          </svg>
        </a>
      </div>

      <span class="sep"></span>

      <!-- Content icons (podcast, music, languages, photos, travel) -->
      <div class="icon-group">
        <a href="/podcast" class:list={[{ active: isActive('/podcast') }]} title="Podcast" aria-label="Podcast">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
            <line x1="12" y1="19" x2="12" y2="23"/>
            <line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
        </a>
        <a href="/music" class:list={[{ active: isActive('/music') }]} title="Music" aria-label="Music">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 18V5l12-2v13"/>
            <circle cx="6" cy="18" r="3"/>
            <circle cx="18" cy="16" r="3"/>
          </svg>
        </a>
        <a href="/languages" class:list={[{ active: isActive('/languages') }]} title="Languages" aria-label="Languages">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </a>
        <a href="/photos" class:list={[{ active: isActive('/photos') }]} title="Photos" aria-label="Photos">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </a>
        <a href="/travel" class:list={[{ active: isActive('/travel') }]} title="Travel" aria-label="Travel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
        </a>
      </div>

      <span class="sep"></span>

      <!-- Social icons -->
      <div class="icon-group">
        <a href="https://x.com/ozamert" target="_blank" rel="noopener noreferrer" title="X (Twitter)" aria-label="X (Twitter)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://github.com/ozamert" target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      </div>

      <!-- Utility icons -->
      <div class="icon-group">
        <a href="/rss.xml" title="RSS Feed" aria-label="RSS Feed">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1" fill="currentColor"/>
          </svg>
        </a>
        <button class="icon-btn theme-toggle" title="Toggle theme" aria-label="Toggle theme">
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <line x1="12" y1="2" x2="12" y2="4"/>
            <line x1="12" y1="20" x2="12" y2="22"/>
            <line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/>
            <line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/>
            <line x1="2" y1="12" x2="4" y2="12"/>
            <line x1="20" y1="12" x2="22" y2="12"/>
            <line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/>
            <line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 16px 24px;
  }

  nav {
    display: flex;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .site-name {
    font-family: var(--font-inter, Inter, sans-serif);
    font-size: 16px;
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .site-name:hover { color: var(--hi); }

  .spacer { flex: 1; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Tech monogram badges (DE · DS · MLE) */
  .badge-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .badge {
    font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 4px 8px;
    border: 1px solid var(--border);
    color: var(--fg);
    opacity: 0.6;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 160ms ease, border-color 160ms ease, color 160ms ease;
  }
  .badge:hover {
    opacity: 1;
    color: var(--hi);
    border-color: var(--border-strong);
  }
  .badge.active {
    opacity: 1;
    color: var(--hi);
    border-color: var(--border-strong);
    background: var(--dot-grid);
  }

  /* Work group (projects text + demos icon) */
  .work-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .text-link {
    font-family: var(--font-inter, Inter, sans-serif);
    font-size: 14px;
    color: var(--fg);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 160ms ease, color 160ms ease;
  }
  .text-link:hover, .text-link.active {
    opacity: 1;
    color: var(--hi);
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
    opacity: 0.6;
    text-decoration: none;
    transition: opacity 160ms ease, color 160ms ease;
  }
  .icon-link:hover, .icon-link.active {
    opacity: 1;
    color: var(--hi);
  }

  /* Separator dots */
  .sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  /* Icon groups (hobby + social + utility) */
  .icon-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .icon-group a,
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
    opacity: 0.6;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: opacity 160ms ease, color 160ms ease;
  }
  .icon-group a:hover,
  .icon-btn:hover,
  .icon-group a.active {
    opacity: 1;
    color: var(--hi);
  }

  @media (max-width: 768px) {
    .nav-right { gap: 10px; }
    .badge { font-size: 10px; padding: 3px 6px; }
    .badge-group, .icon-group, .work-group { gap: 8px; }
    .sep { display: none; }
  }

  /* Sun/moon icon swap — show moon when dark, sun when light */
  .theme-toggle .icon-sun { display: none; }
  .theme-toggle .icon-moon { display: inline-flex; }
  :global(html[data-theme="light"]) .theme-toggle .icon-moon { display: none; }
  :global(html[data-theme="light"]) .theme-toggle .icon-sun { display: inline-flex; }
</style>

<script is:inline>
  (function() {
    var btn = document.querySelector('.theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'light' ? 'dark' : 'light';
      if (next === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
    });
  })();
</script>
