---
interface Props {
  label: string;
  icon?: string;
  color?: string;
}

const { label, icon, color } = Astro.props;
---

<span class="chip" style={color ? `--chip-accent: ${color};` : ''}>
  {icon && <span class="chip-icon">{icon}</span>}
  <span class="chip-label">{label}</span>
</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--dot-grid);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 3px;
    font-family: var(--font-inter, Inter, sans-serif);
    font-size: 14px;
    color: var(--fg);
    vertical-align: middle;
    margin: 0 2px;
    line-height: 1.5;
  }

  .chip-icon {
    font-size: 13px;
    line-height: 1;
  }

  .chip-label {
    white-space: nowrap;
  }
</style>
