<style>
  .social-cluster {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .find-label {
    font-family: var(--font-inter, Inter, sans-serif);
    font-size: 14px;
    color: #e5e7eb;
    opacity: 0.5;
    margin-bottom: 12px;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-inter, Inter, sans-serif);
    font-size: 14px;
    color: #e5e7eb;
    text-decoration: none;
    opacity: 0.7;
  }

  .social-links a:hover {
    opacity: 1;
    color: #ffffff;
  }

  .social-links svg {
    flex-shrink: 0;
  }
</style>
