---
// Footer — plain text links, minimal
---

<footer>
  <div class="footer-links">
    <a href="https://github.com/ozamert" target="_blank" rel="noopener noreferrer">GitHub</a>
    <span class="sep">&middot;</span>
    <a href="https://x.com/ozamert" target="_blank" rel="noopener noreferrer">X</a>
    <span class="sep">&middot;</span>
    <a href="https://linkedin.com/in/ozamert" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <span class="sep">&middot;</span>
    <a href="/rss.xml">RSS</a>
    <span class="sep">&middot;</span>
    <a href="mailto:hello@ozamert.com">Email</a>
  </div>
  <p class="copyright">&copy; 2026 Mert &Ouml;zt&uuml;rk</p>
</footer>

<style>
  footer {
    padding: 48px 24px;
    text-align: center;
    border-top: 1px solid var(--watermark);
  }

  .footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .footer-links a {
    font-family: var(--font-inter, Inter, sans-serif);
    font-size: 14px;
    color: var(--fg);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.15s ease, color 0.15s ease;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--hi);
  }

  .sep {
    color: var(--fg);
    opacity: 0.3;
    font-size: 14px;
    user-select: none;
  }

  .copyright {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    color: var(--fg);
    opacity: 0.4;
    margin: 0;
  }
</style>
