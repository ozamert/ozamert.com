---
// Static moon icon — dark only, no JS
---

<button class="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    color: #e5e7eb;
    opacity: 0.6;
    border-radius: 4px;
    transition: opacity 0.15s ease;
  }

  .theme-toggle:hover {
    opacity: 1;
  }
</style>
